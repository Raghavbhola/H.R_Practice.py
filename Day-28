#This is bubble sort question.

n = ['b','a','dd','ccc']
pointer = 0     #swap counter
for i in range(len(n)):
    for j in range(len(n)-1):
        if n[j] > n[j+1]:
            n[j], n[j+1] =n[j+1], n[j]  # this is for comparison
            pointer += 1   
print(pointer)
# print(i)
print("Sorted elements:", n)

